     set Data file name = temp_base.txt
   end
end

subsection Compositional fields
   set Number of fields = 1
   set Names of fields  = ocrust
end

subsection Initial composition model
  set Model name = ascii data

  subsection Ascii data model
     set Data directory = /home/vxt195/work/inputs/text_file_inputs/whole_domain/
     set Data file name = base_comp.txt
   end
  
