#------- boundary conditions -------------

subsection Boundary temperature model
  set Fixed temperature boundary indicators = top, left 
  set List of model names = initial temperature
end

subsection Boundary heat flux model
  set Fixed heat flux boundary indicators = bottom, right
  set Model name = function

  subsection Function
    set Function expression = 0
  end
end

subsection Boundary composition model
  set Model name = initial composition
  set Fixed composition boundary indicators = left
end

#subsection Boundary traction model
#  set Prescribed traction boundary indicators = left y:zero traction, right y:zero traction
#end



subsection Boundary traction model
  set Prescribed traction boundary indicators = right:initial lithostatic pressure, left y:initial lithostatic pressure

  subsection Initial lithostatic pressure
    set Representative point = 660e3,0
  end
end



subsection Boundary velocity model
  set Tangential velocity boundary indicators = bottom #left, bnottom
  #set Zero velocity boundary indicators = right
  set Prescribed velocity boundary indicators = left:function, top y: zero velocity

  subsection Function
    set Coordinate system   = cartesian
    set Variable names      = x,y
    set Function constants  = H =660.e3, plen=50.e3, v = 0.05, xmax=1320.e3, x1=200.e3, y1=250.e3, rad=1250.e3i, es=200.e3       	 # Change Entire Model Thickness Here
    set Function expression = if(y>H-100.e3 && x < plen, v, \
                                if(y>=H-es && (x<plen), v + (v/200.e3)*(y-H+100.e3),0)); \
                              0 
  end
end

