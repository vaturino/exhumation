#-------------------------------------

#-------- material model -------------
subsection Material model
  set Model name = visco plastic

  subsection Visco Plastic 

    # reference stuff
    set Reference temperature =   1694.4
    #set Reference viscosity   =   2.5e20
    set Reference strain rate =   1e-20
    set Minimum strain rate   =   1.e-20
    set Adiabat temperature gradient for viscosity =   9.24e-09 # 0.3 K/km

    # set Pore fluid cutoff depth = 30e3
    # set Fluid ratio = 0, 0.6, 0, 0, 0
    # set Include pore fluid pressure = true
    
    
    # Set up phase transitions so that crust becomes background material past 100 km, and
    # # dislocation becomes inactive in the lower mantle for all fields.
     set Phase transition depths           =   background: 400e3,   ocrust: 80e3|400e3
     set Phase transition widths           =   background: 1e3,   ocrust: 1e3|1e3
     set Phase transition temperatures     =   background: 1694.5,   ocrust: 1694.5|1694.5
     set Phase transition Clapeyron slopes =   background: 0,   ocrust: 0|0
    
    
    # Viscosity cut offs
    set Minimum viscosity   =   background: 2.5e18|2.5e18, ocrust:1.95e20|2.5e18|2.5e18
    set Maximum viscosity   =   background: 2.5e23|2.5e23, ocrust:2.05e20|2.5e23|2.5e23

    
    # density-related parameters (crust has mantle density = 3300 at T = 273 K)
    set Thermal diffusivities  =   1e-6
    set Heat capacities        =   750

    # Densities are set so that at surface temperatures they will be at 3300, 3175, 3175, and 2800.
    set Densities              =   3300
    set Thermal expansivities  =   3e-5
    
    
    # viscosity-related parameters (mantle, crust)
    # at ref conditions (1e-15s-1,330km,1573K + adiabatic): 
    # ... visc diff = visc disl = 5e20. thus, composition visc = 2.5e20
    set Viscous flow law            =   composite
    set Viscosity averaging scheme  =   geometric

    # dislocation creep (just z < 660 km)
    # We set the prefactor to a very low value in the lower mantle to effectively turn off dislocation creep.
    set Prefactors for dislocation creep          =   1e-45
    set Stress exponents for dislocation creep    =   3.5
    set Activation energies for dislocation creep =   540.e3
    set Activation volumes for dislocation creep  =   12e-6

    # diffusion creep (lm/um viscosity >= 20), in the lower mantle (gives lower/upper mantle viscosity = 20)
    set Prefactors for diffusion creep              =   1.199915e-11
    set Stress exponents for diffusion creep        =   1
    set Grain size exponents for diffusion creep    =   0
    set Activation energies for diffusion creep     =   300e3
    set Activation volumes for diffusion creep      =   4e-6

    # Plasticity parameters using drucker-prager, with cohesions set to mimic 60e6 in byerlee.
    set Cohesions                   =   150e10


    # Friction angle set to mimic byerlee's law with a coefficient of friction of 0.6 and a prefactor of 0.15
    set Angles of internal friction =  0
    #set Maximum yield stress = 0.5e9
  end



end
#-------------------------------------

# --------- other stuff -------------
set Pressure normalization            = no
set Surface pressure                  = 0
set Adiabatic surface temperature     = 1694.5

subsection Gravity model
  set Model name = vertical

  subsection Vertical
    set Magnitude = 9.81
  end
end

subsection Formulation
  set Formulation = Boussinesq approximation
end
#-------------------------------------

#--------- postprocessing ------------
subsection Postprocess
  set List of postprocessors = visualization, basic statistics, velocity statistics

  subsection Visualization
    set List of output variables = viscosity, strain rate, nonadiabatic pressure, shear stress, stress, named additional outputs, density, adiabat
    set Output format                 = vtu
    set Time between graphical output = 0.1e6
    set Interpolate output = true
    set Point-wise stress and strain = true
    set Write higher order output = true
    set Number of grouped files = 2
  end
end
#-------------------------------------

#--------- checkpointing -------------
subsection Checkpointing
  set Steps between checkpoint = 10
end
