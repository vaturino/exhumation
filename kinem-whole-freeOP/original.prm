# set Additional shared libraries = ./libprescribed_velocity.so

set Dimension                              = 2
set Use years in output instead of seconds = true
set End time                               = 10e6
set Output directory                       = outputs/kinem-whole-tns

### SOLVER STUFF
# non-linear stuff
set Nonlinear solver scheme                = single Advection, iterated Stokes
set Nonlinear solver tolerance             = 1.0e-4
set Max nonlinear iterations               = 20
set Max nonlinear iterations in pre-refinement = 20
set CFL number                             = 0.5   #0.25
# set Maximum relative increase in time step = 50    #50
set Resume computation			               = false 
set Timing output frequency                = 1

# linear solver stuff 
subsection Solver parameters
  subsection Stokes solver parameters
    set Linear solver tolerance  		= 1.0e-4
    set Number of cheap Stokes solver steps     = 200
  end
  set Temperature solver tolerance        = 1e-10
  set Composition solver tolerance        = 1e-10
end
subsection Discretization
 set Temperature polynomial degree       = 2
 set Composition polynomial degree       = 2
end

#------ domain and meshing -----------
subsection Geometry model
  set Model name = box

  subsection Box
    set Y extent =  660e3
    set X extent = 1320.e3
    #set X repetitions = 4
    #set Y repetitions = 1
  end

end

subsection Mesh refinement
  ## at 5 (6 levels) will be 5 km.

  set Initial global refinement                = 4
  set Initial adaptive refinement              = 5 #3
  set Time steps between mesh refinement       = 1
  set Refinement fraction                      = 0.7   #0.4
  set Coarsening fraction                      = 0.2  #0.2
  set Strategy                                 = viscosity, composition, minimum refinement function
  set Refinement criteria scaling factors      = 2, 1, 1
  set Refinement criteria merge operation      = max
  set Run postprocessors on initial refinement = false

  subsection Composition threshold
    set Compositional field thresholds         = 0.1
  end

